#!/usr/bin/env bash
set -euo pipefail

BIN="${HOME}/.local/bin/solverforge-screensaver"
if [[ -x "$BIN" ]]; then
  exec "$BIN" "$@"
fi

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
PROJECT_DIR=$(cd -- "$SCRIPT_DIR/.." && pwd)
DEV_BIN="$PROJECT_DIR/target/release/solverforge-screensaver"
if [[ -x "$DEV_BIN" ]]; then
  exec "$DEV_BIN" "$@"
fi

echo "solverforge-screensaver: not installed. Run scripts/install-linux.sh or make install-linux" >&2
exit 1
