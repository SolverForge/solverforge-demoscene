#!/usr/bin/env bash
set -euo pipefail

SELF_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
PROJECT_DIR=$(cd -- "$SELF_DIR/.." && pwd)
INSTALL_PREFIX="${HOME}/.local"
BIN_PATH="$INSTALL_PREFIX/bin/solverforge-screensaver"
LAUNCH_PATH="$INSTALL_PREFIX/bin/solverforge-screensaver-launch"
DESKTOP_PATH="$INSTALL_PREFIX/share/applications/solverforge-screensaver.desktop"
HYPR_CONFIG_DIR="$HOME/.config/hypr"
HYPR_IDLE_MAIN_CONF="$HYPR_CONFIG_DIR/hypridle.conf"
HYPR_IDLE_INCLUDE_CONF="$HYPR_CONFIG_DIR/solverforge-screensaver.conf"
SYSTEMD_USER_DIR="$HOME/.config/systemd/user"
XAUTOLOCK_SERVICE="$SYSTEMD_USER_DIR/solverforge-screensaver-xautolock.service"
SWAYIDLE_SERVICE="$SYSTEMD_USER_DIR/solverforge-screensaver-swayidle.service"
TIMEOUT_SECONDS=300

usage() {
  cat <<USAGE
Usage: $(basename "$0") <install|run|set|unset|status> [options]

Commands:
  install            Build and install the screensaver into ~/.local/bin
  run                Launch the screensaver now
  set [--timeout N]  Configure idle launch on Linux (hypridle, swayidle, or xautolock)
  unset              Remove idle-launch configuration
  status             Show installed/configured state
USAGE
}

ensure_installed() {
  if [[ ! -x "$BIN_PATH" ]]; then
    echo "screensaver is not installed at $BIN_PATH" >&2
    echo "Run: $(basename "$0") install" >&2
    exit 1
  fi
}

require_command() {
  local cmd=$1
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "missing required command: $cmd" >&2
    exit 1
  fi
}

validate_timeout() {
  if [[ ! "$TIMEOUT_SECONDS" =~ ^[0-9]+$ ]] || (( TIMEOUT_SECONDS <= 0 )); then
    echo "timeout must be a positive integer number of seconds" >&2
    exit 1
  fi
}

install_cmd() {
  "$PROJECT_DIR/scripts/install-linux.sh"
}

run_cmd() {
  ensure_installed
  exec "$LAUNCH_PATH"
}

hypr_include_attached() {
  [[ -f "$HYPR_IDLE_MAIN_CONF" ]] && grep -Fqx "source = $HYPR_IDLE_INCLUDE_CONF" "$HYPR_IDLE_MAIN_CONF"
}

attach_hypr_include() {
  mkdir -p "$HYPR_CONFIG_DIR"
  touch "$HYPR_IDLE_MAIN_CONF"
  if ! hypr_include_attached; then
    printf '\nsource = %s\n' "$HYPR_IDLE_INCLUDE_CONF" >> "$HYPR_IDLE_MAIN_CONF"
  fi
}

remove_hypr_include() {
  [[ -f "$HYPR_IDLE_MAIN_CONF" ]] || return 0

  local temp_file
  temp_file=$(mktemp)
  grep -Fvx "source = $HYPR_IDLE_INCLUDE_CONF" "$HYPR_IDLE_MAIN_CONF" > "$temp_file" || true
  mv "$temp_file" "$HYPR_IDLE_MAIN_CONF"
}

write_hypridle_config() {
  mkdir -p "$HYPR_CONFIG_DIR"
  cat > "$HYPR_IDLE_INCLUDE_CONF" <<CFG
# solverforge-screensaverctl generated
listener {
    timeout = ${TIMEOUT_SECONDS}
    on-timeout = ${LAUNCH_PATH}
    on-resume = pkill -x solverforge-screensaver || true
}
CFG

  attach_hypr_include
  echo "Configured hypridle include: $HYPR_IDLE_INCLUDE_CONF"
  echo "If hypridle is already running, restart it or re-login to apply changes."
}

write_xautolock_service() {
  require_command systemctl
  require_command xautolock

  mkdir -p "$SYSTEMD_USER_DIR"
  local minutes=$(( (TIMEOUT_SECONDS + 59) / 60 ))
  cat > "$XAUTOLOCK_SERVICE" <<SERVICE
[Unit]
Description=SolverForge Screensaver via xautolock

[Service]
ExecStart=/usr/bin/env xautolock -time ${minutes} -locker ${LAUNCH_PATH} -detectsleep
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
SERVICE

  systemctl --user daemon-reload
  systemctl --user enable --now solverforge-screensaver-xautolock.service
  echo "Configured xautolock user service: $XAUTOLOCK_SERVICE"
}

write_swayidle_service() {
  require_command systemctl
  require_command swayidle

  mkdir -p "$SYSTEMD_USER_DIR"
  cat > "$SWAYIDLE_SERVICE" <<SERVICE
[Unit]
Description=SolverForge Screensaver via swayidle

[Service]
ExecStart=/usr/bin/env swayidle -w timeout ${TIMEOUT_SECONDS} '${LAUNCH_PATH}' resume 'pkill -x solverforge-screensaver || true' before-sleep 'pkill -x solverforge-screensaver || true'
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
SERVICE

  systemctl --user daemon-reload
  systemctl --user enable --now solverforge-screensaver-swayidle.service
  echo "Configured swayidle user service: $SWAYIDLE_SERVICE"
}

set_cmd() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout)
        [[ $# -ge 2 ]] || { echo "--timeout requires a value" >&2; exit 1; }
        TIMEOUT_SECONDS="$2"
        shift 2
        ;;
      *)
        echo "Unknown option: $1" >&2
        usage
        exit 1
        ;;
    esac
  done

  validate_timeout
  ensure_installed

  if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" || -f "$HYPR_IDLE_MAIN_CONF" ]]; then
    write_hypridle_config
    return
  fi

  if [[ -n "${WAYLAND_DISPLAY:-}" && ( "${XDG_CURRENT_DESKTOP:-}" == *sway* || -n "${SWAYSOCK:-}" ) ]]; then
    write_swayidle_service
    return
  fi

  if [[ -n "${DISPLAY:-}" ]]; then
    write_xautolock_service
    return
  fi

  cat >&2 <<MSG
Could not auto-configure an idle manager for this Linux session.
Supported auto-set paths right now:
  - Hyprland / hypridle
  - sway / swayidle
  - X11 / xautolock

The screensaver is installed and can still be run manually with:
  $LAUNCH_PATH
MSG
  exit 1
}

unset_cmd() {
  remove_hypr_include
  rm -f "$HYPR_IDLE_INCLUDE_CONF"

  if command -v systemctl >/dev/null 2>&1; then
    systemctl --user disable --now solverforge-screensaver-xautolock.service >/dev/null 2>&1 || true
    systemctl --user disable --now solverforge-screensaver-swayidle.service >/dev/null 2>&1 || true
    systemctl --user daemon-reload >/dev/null 2>&1 || true
  fi

  rm -f "$XAUTOLOCK_SERVICE" "$SWAYIDLE_SERVICE"
  echo "Removed screensaver idle configuration."
}

status_cmd() {
  echo "binary:   $( [[ -x "$BIN_PATH" ]] && echo installed || echo missing )"
  echo "launcher: $( [[ -x "$LAUNCH_PATH" ]] && echo installed || echo missing )"
  echo "desktop:  $( [[ -f "$DESKTOP_PATH" ]] && echo installed || echo missing )"
  echo "hypridle include: $( [[ -f "$HYPR_IDLE_INCLUDE_CONF" ]] && echo configured || echo not-configured )"
  echo "hypridle source:  $( hypr_include_attached && echo attached || echo detached )"
  echo "xautolock service: $( [[ -f "$XAUTOLOCK_SERVICE" ]] && echo configured || echo not-configured )"
  echo "swayidle service:  $( [[ -f "$SWAYIDLE_SERVICE" ]] && echo configured || echo not-configured )"
}

cmd="${1:-}"
case "$cmd" in
  install) shift; install_cmd "$@" ;;
  run) shift; run_cmd "$@" ;;
  set) shift; set_cmd "$@" ;;
  unset) shift; unset_cmd "$@" ;;
  status) shift; status_cmd "$@" ;;
  ""|-h|--help|help) usage ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
